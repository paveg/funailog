---
import type { CollectionEntry } from 'astro:content';

import Budoux from '@/components/Budoux.astro';
import { defaultLang } from '@/i18n/ui';
import { useTranslations } from '@/i18n/utils';

export type Props = {
  currentPost: CollectionEntry<'blog'>;
  seriesPosts: CollectionEntry<'blog'>[];
};

const { currentPost, seriesPosts } = Astro.props;
const t = useTranslations(defaultLang);
const currentOrder = currentPost.data.seriesOrder ?? 0;
const total = seriesPosts.length;
const prevPost = seriesPosts.find(
  (p) => p.data.seriesOrder === currentOrder - 1,
);
const nextPost = seriesPosts.find(
  (p) => p.data.seriesOrder === currentOrder + 1,
);
---

{
  seriesPosts.length > 1 && (
    <nav id="series-nav" aria-label={t('series.ariaLabel')} class="my-6">
      {/* Step indicator */}
      <div class="mb-3 flex items-center gap-3">
        <span class="text-muted-foreground shrink-0 text-xs font-medium tracking-wide">
          {t('series.label')}
        </span>
        <div class="flex items-center gap-1.5">
          {seriesPosts.map((post, i) => {
            const order = post.data.seriesOrder ?? i + 1;
            const isCurrent = post.id === currentPost.id;
            const isPast = order < currentOrder;
            return (
              <>
                {i > 0 && (
                  <div
                    class:list={[
                      'h-px w-4',
                      isPast || isCurrent ? 'bg-foreground/30' : 'bg-border',
                    ]}
                  />
                )}
                {isCurrent ? (
                  <div
                    class="bg-foreground text-background flex size-5 items-center justify-center rounded-full text-[10px] font-bold"
                    aria-current="step"
                  >
                    {order}
                  </div>
                ) : (
                  <a
                    href={`/blog/${post.id}#series-nav`}
                    class:list={[
                      'flex size-5 items-center justify-center rounded-full text-[10px] font-medium transition-colors duration-150',
                      isPast
                        ? 'bg-foreground/15 text-foreground hover:bg-foreground/25'
                        : 'bg-muted text-muted-foreground hover:bg-foreground/15 hover:text-foreground',
                    ]}
                  >
                    {order}
                  </a>
                )}
              </>
            );
          })}
        </div>
        <span class="text-muted-foreground/60 text-xs">
          {currentOrder}/{total}
        </span>
      </div>

      {/* Prev / Next cards */}
      <div
        class:list={[
          'grid gap-3',
          prevPost && nextPost ? 'grid-cols-2' : 'grid-cols-1',
        ]}
      >
        {prevPost && (
          <a
            href={`/blog/${prevPost.id}#series-nav`}
            class="border-border hover:border-accent-line hover:bg-surface-sunken group flex items-start gap-2 rounded-lg border p-3 transition-all duration-150"
          >
            <svg
              class="text-muted-foreground mt-0.5 size-3.5 shrink-0"
              viewBox="0 0 15 15"
              fill="none"
            >
              <path
                d="M8.842 3.135a.5.5 0 0 1 .023.707L5.435 7.5l3.43 3.658a.5.5 0 0 1-.73.684l-3.75-4a.5.5 0 0 1 0-.684l3.75-4a.5.5 0 0 1 .707-.023Z"
                fill="currentColor"
              />
            </svg>
            <div class="min-w-0">
              <span class="text-muted-foreground block text-[10px] tracking-wider uppercase">
                Part {prevPost.data.seriesOrder ?? 0}
              </span>
              <span
                class="text-foreground group-hover:text-link font-heading line-clamp-1 block text-sm leading-snug font-medium transition-colors"
                data-budoux
              >
                <Budoux text={prevPost.data.title} />
              </span>
            </div>
          </a>
        )}
        {nextPost && (
          <a
            href={`/blog/${nextPost.id}#series-nav`}
            class:list={[
              'border-border hover:border-accent-line hover:bg-surface-sunken group flex items-start gap-2 rounded-lg border p-3 transition-all duration-150',
              prevPost ? 'text-right' : 'flex-row-reverse text-right',
            ]}
          >
            <div class="min-w-0 flex-1">
              <span class="text-muted-foreground block text-[10px] tracking-wider uppercase">
                Part {nextPost.data.seriesOrder ?? 0}
              </span>
              <span
                class="text-foreground group-hover:text-link font-heading line-clamp-1 block text-sm leading-snug font-medium transition-colors"
                data-budoux
              >
                <Budoux text={nextPost.data.title} />
              </span>
            </div>
            <svg
              class="text-muted-foreground mt-0.5 size-3.5 shrink-0"
              viewBox="0 0 15 15"
              fill="none"
            >
              <path
                d="M6.158 3.135a.5.5 0 0 0-.023.707L9.565 7.5l-3.43 3.658a.5.5 0 0 0 .73.684l3.75-4a.5.5 0 0 0 0-.684l-3.75-4a.5.5 0 0 0-.707-.023Z"
                fill="currentColor"
              />
            </svg>
          </a>
        )}
      </div>
    </nav>
  )
}
