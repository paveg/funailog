---

---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Style Guide — funailog Design System</title>
    <style>
      @import '../styles/theme.css';

      body {
        font-family: var(--font-body);
        background: var(--background);
        color: var(--foreground);
        margin: 0;
        padding: 0;
        transition:
          background 0.2s,
          color 0.2s;
      }

      .styleguide {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }

      .styleguide-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 3rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border);
      }

      .styleguide-header h1 {
        font-family: var(--font-heading);
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
      }

      .theme-toggle {
        padding: 0.5rem 1rem;
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        background: var(--surface-elevated);
        color: var(--foreground);
        cursor: pointer;
        font-family: var(--font-body);
        font-size: 0.875rem;
      }

      section {
        margin-bottom: 3rem;
      }

      section > h2 {
        font-family: var(--font-heading);
        font-size: 1.25rem;
        font-weight: 600;
        margin: 0 0 1.5rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border);
      }

      .swatch-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 1rem;
      }

      .swatch {
        border-radius: var(--radius-md);
        overflow: hidden;
        border: 1px solid var(--border);
      }

      .swatch-color {
        height: 64px;
      }

      .swatch-label {
        padding: 0.5rem 0.75rem;
        font-size: 0.75rem;
        font-family: var(--font-code);
        background: var(--surface-elevated);
      }

      .swatch-label span {
        display: block;
        color: var(--muted-foreground);
        margin-top: 0.125rem;
      }

      .surface-demo {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
      }

      .surface-card {
        padding: 1.5rem;
        border-radius: var(--radius-lg);
      }

      .surface-card h3 {
        font-family: var(--font-heading);
        font-size: 1rem;
        font-weight: 600;
        margin: 0 0 0.5rem;
      }

      .surface-card p {
        font-size: 0.875rem;
        color: var(--muted-foreground);
        margin: 0;
        line-height: 1.6;
      }

      .shadow-demo {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
      }

      .shadow-card {
        padding: 1.5rem;
        border-radius: var(--radius-lg);
        background: var(--surface-elevated);
        border: 1px solid var(--border-elevated);
        text-align: center;
      }

      .shadow-card p {
        margin: 0;
        font-size: 0.75rem;
        font-family: var(--font-code);
        color: var(--muted-foreground);
      }
    </style>
  </head>
  <body>
    <div class="styleguide">
      <header class="styleguide-header">
        <h1>funailog Design System</h1>
        <button class="theme-toggle" id="themeToggle">Toggle Dark Mode</button>
      </header>

      <!-- Colors -->
      <section>
        <h2>Colors</h2>
        <div class="swatch-grid">
          <div class="swatch">
            <div class="swatch-color" style="background: var(--background);">
            </div>
            <div class="swatch-label">background<span>--background</span></div>
          </div>
          <div class="swatch">
            <div class="swatch-color" style="background: var(--foreground);">
            </div>
            <div class="swatch-label">foreground<span>--foreground</span></div>
          </div>
          <div class="swatch">
            <div class="swatch-color" style="background: var(--primary);"></div>
            <div class="swatch-label">primary<span>--primary</span></div>
          </div>
          <div class="swatch">
            <div class="swatch-color" style="background: var(--secondary);">
            </div>
            <div class="swatch-label">secondary<span>--secondary</span></div>
          </div>
          <div class="swatch">
            <div class="swatch-color" style="background: var(--muted);"></div>
            <div class="swatch-label">muted<span>--muted</span></div>
          </div>
          <div class="swatch">
            <div class="swatch-color" style="background: var(--accent);"></div>
            <div class="swatch-label">accent<span>--accent</span></div>
          </div>
          <div class="swatch">
            <div class="swatch-color" style="background: var(--border);"></div>
            <div class="swatch-label">border<span>--border</span></div>
          </div>
          <div class="swatch">
            <div class="swatch-color" style="background: var(--link);"></div>
            <div class="swatch-label">link<span>--link</span></div>
          </div>
          <div class="swatch">
            <div class="swatch-color" style="background: var(--destructive);">
            </div>
            <div class="swatch-label">
              destructive<span>--destructive</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Surfaces -->
      <section>
        <h2>Surfaces</h2>
        <div class="surface-demo">
          <div class="surface-card" style="background: var(--background);">
            <h3>Background</h3>
            <p>ページの基底面。コンテンツの背景。</p>
          </div>
          <div
            class="surface-card"
            style="background: var(--surface-elevated); box-shadow: var(--shadow-sm); border: 1px solid var(--border-elevated);"
          >
            <h3>Surface Elevated</h3>
            <p>
              カードやポップオーバー。背景から浮き上がった面。ライトモードではシャドウ、ダークモードでは微細ボーダーで表現。
            </p>
          </div>
          <div class="surface-card" style="background: var(--surface-sunken);">
            <h3>Surface Sunken</h3>
            <p>入力欄やコード枠。背景より沈んだ面。</p>
          </div>
        </div>
      </section>

      <!-- Shadows -->
      <section>
        <h2>Shadows</h2>
        <div class="shadow-demo">
          <div class="shadow-card" style="box-shadow: var(--shadow-xs);">
            <p>--shadow-xs</p>
          </div>
          <div class="shadow-card" style="box-shadow: var(--shadow-sm);">
            <p>--shadow-sm</p>
          </div>
          <div class="shadow-card" style="box-shadow: var(--shadow);">
            <p>--shadow</p>
          </div>
          <div class="shadow-card" style="box-shadow: var(--shadow-md);">
            <p>--shadow-md</p>
          </div>
        </div>
      </section>
    </div>

    <script>
      const toggle = document.getElementById('themeToggle');
      const saved = localStorage.getItem('theme');
      if (saved === 'dark') document.documentElement.classList.add('dark');

      toggle?.addEventListener('click', () => {
        document.documentElement.classList.toggle('dark');
        const isDark = document.documentElement.classList.contains('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        toggle.textContent = isDark ? 'Toggle Light Mode' : 'Toggle Dark Mode';
      });

      if (document.documentElement.classList.contains('dark')) {
        toggle.textContent = 'Toggle Light Mode';
      }
    </script>
  </body>
</html>
