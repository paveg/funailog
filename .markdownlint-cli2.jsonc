{
  "config": {
    "extends": "./.markdownlint.jsonc",
  },
  "globs": ["**/*.md", "**/*.mdx"],
  "ignores": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.astro/**",
    "**/.firecrawl/**",
    "NOTES.md",
    "src/content/blog/2026/review-benq-screenbar-halo.mdx",
    "docs/superpowers/**",
    "**/CHANGELOG.md",
  ],
  "customRules": [],
  "markdownItPlugins": [],
  "fix": false,
}
