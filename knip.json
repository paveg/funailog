{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/pages/**/*.{astro,ts,tsx}",
    "src/content/**/*.mdx",
    "src/utils/clean.ts",
    "scripts/**/*.ts",
    "e2e/**/*.ts"
  ],
  "project": ["src/**/*.{ts,tsx,astro}", "scripts/**/*.ts"],
  "ignoreDependencies": [
    "@textlint-ja/textlint-rule-preset-ai-writing",
    "textlint-plugin-mdx",
    "lightningcss",
    "tailwindcss-animate",
    "@eslint/eslintrc",
    "@fontsource-variable/jetbrains-mono",
    "@fontsource/line-seed-jp"
  ]
}
