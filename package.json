{
  "name": "funailog",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "author": "paveg_",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "preview": "astro preview",
    "astro": "astro",
    "prebuild": "tsx src/utils/clean.ts",
    "build": "astro build && rm -rf dist/styleguide",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "playwright test",
    "prelint": "astro sync",
    "lint": "run-p --aggregate-output --continue-on-error \"lint:*\"",
    "lint:astro": "astro check",
    "lint:content": "tsx scripts/validate-content.ts",
    "lint:eslint": "eslint --cache .",
    "lint:format": "prettier --check .",
    "lint:knip": "knip --include files,dependencies,unlisted",
    "lint:md": "markdownlint-cli2",
    "lint:textlint": "textlint \"src/content/blog/**/*.mdx\" \"src/content/page/**/*.mdx\"",
    "lint:types": "tsc --noEmit",
    "fix": "run-s fix:format fix:eslint fix:md fix:textlint",
    "fix:eslint": "eslint --cache --fix .",
    "fix:format": "prettier --write .",
    "fix:md": "markdownlint-cli2 --fix",
    "fix:textlint": "textlint --fix \"src/content/blog/**/*.mdx\" \"src/content/page/**/*.mdx\"",
    "cv": "tsx scripts/generate-cv.ts",
    "cv:en": "tsx scripts/generate-cv.ts --en",
    "link-cards:warm": "tsx scripts/link-cards.ts warm",
    "link-cards:prune": "tsx scripts/link-cards.ts prune",
    "link-cards:list": "tsx scripts/link-cards.ts list",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,astro,js,mjs}": [
      "eslint --cache --fix"
    ],
    "*.{md,mdx}": [
      "markdownlint-cli2 --fix"
    ],
    "src/content/blog/**/*.mdx": [
      "tsx scripts/validate-content.ts"
    ],
    "*.{ts,tsx,astro,js,mjs,css,md,mdx,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@fontsource/line-seed-jp": "5.2.1",
    "@radix-ui/react-icons": "^1.3.2",
    "@react-pdf/renderer": "^4.3.1",
    "@tailwindcss/vite": "4.2.1",
    "astro": "^6.1.10",
    "astro-embed": "0.12.0",
    "budoux": "0.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-hierarchy": "3.1.2",
    "framer-motion": "12.38.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rehype-mermaid": "3.0.0",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "remark-mdx": "3.1.1",
    "remark-parse": "11.0.0",
    "schema-dts": "^1.1.5",
    "tailwind-merge": "^2.2.2",
    "tailwindcss": "4.2.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "glob@<10.5.0": "^10.5.0",
      "rollup@>=4.0.0 <4.59.0": "^4.59.0",
      "minimatch@<3.1.4": "^3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "^9.0.9",
      "svgo@4.0.0": "^4.0.1",
      "fast-xml-parser@<5.7.0": "^5.7.0",
      "fast-xml-builder@<=1.1.6": "^1.1.7",
      "fast-uri@<3.1.2": "^3.1.2",
      "lodash@<4.17.24": "^4.17.24",
      "lodash-es@<4.18.1": "^4.18.1",
      "flatted@<3.4.2": "^3.4.2",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "devalue@<5.8.1": "^5.8.1",
      "uuid@<11.1.1": "^11.1.1",
      "qs@>=6.11.1 <=6.15.1": "^6.15.2",
      "hono@<4.12.18": "^4.12.18",
      "ip-address@<=10.1.0": "^10.1.1",
      "postcss@<8.5.10": "^8.5.10",
      "markdown-it@>=13.0.0 <14.1.1": "^14.1.1",
      "smol-toml@<1.6.1": "^1.6.1",
      "dompurify@<3.3.2": "^3.3.3",
      "yaml@>=2.0.0 <2.8.3": "^2.8.3",
      "astro-auto-import@<0.5.1": "^0.5.1"
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@playform/inline": "0.1.2",
    "@playwright/test": "1.60.0",
    "@tailwindcss/typography": "^0.5.19",
    "@textlint-ja/textlint-rule-preset-ai-writing": "^1.6.3",
    "@types/d3-hierarchy": "3.1.7",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "^3.0.3",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "astro-expressive-code": "0.41.7",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^0.33.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "fetch-site-metadata": "^0.2.0",
    "hastscript": "^9.0.1",
    "husky": "^9.1.7",
    "knip": "6.14.1",
    "lightningcss": "^1.30.2",
    "lint-staged": "^15.2.10",
    "markdownlint-cli2": "^0.20.0",
    "mdast-util-to-string": "^4.0.0",
    "npm-run-all2": "9.0.0",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.13.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-parse": "9.0.1",
    "rehype-stringify": "10.0.1",
    "satori": "^0.18.3",
    "sharp": "^0.34.5",
    "textlint": "^15.5.4",
    "textlint-plugin-mdx": "^1.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "unist-util-visit-parents": "6.0.2",
    "vitest": "4.1.2",
    "yaml": "^2.8.2"
  }
}
