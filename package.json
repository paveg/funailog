{
  "name": "funailog",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "author": "paveg_",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "bash -c 'set -e; pids=(); pnpm run format:check & pids+=($!); eslint --cache . & pids+=($!); markdownlint-cli2 & pids+=($!); pnpm run lint:textlint & pids+=($!); pnpm run validate:content & pids+=($!); astro check & pids+=($!); fail=0; for pid in \"${pids[@]}\"; do wait \"$pid\" || fail=1; done; exit $fail'",
    "lint:fix": "eslint --cache --fix . && markdownlint-cli2 --fix",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "lint:textlint": "textlint \"src/content/blog/2026/kubernetes-hard-way-apple-silicon-*.mdx\"",
    "lint:textlint:fix": "textlint --fix \"src/content/blog/2026/kubernetes-hard-way-apple-silicon-*.mdx\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:content": "tsx scripts/validate-content.ts",
    "prebuild": "pnpx tsx ./src/utils/clean.ts",
    "prepare": "husky",
    "cv": "tsx scripts/generate-cv.ts",
    "cv:en": "tsx scripts/generate-cv.ts --en"
  },
  "lint-staged": {
    "*.{ts,tsx,astro,js,mjs}": [
      "eslint --cache --fix"
    ],
    "*.{md,mdx}": [
      "markdownlint-cli2 --fix"
    ],
    "src/content/blog/**/*.mdx": [
      "tsx scripts/validate-content.ts"
    ],
    "*.{ts,tsx,astro,js,mjs,css,md,mdx,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/fira-code": "5.2.7",
    "@fontsource/line-seed-jp": "5.2.1",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-pdf/renderer": "^4.3.1",
    "@tailwindcss/vite": "4.2.1",
    "astro": "^6.1.6",
    "astro-embed": "0.12.0",
    "budoux": "0.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-hierarchy": "3.1.2",
    "framer-motion": "12.38.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rehype-mermaid": "3.0.0",
    "schema-dts": "^1.1.5",
    "tailwind-merge": "^2.2.2",
    "tailwindcss": "4.2.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "glob@<10.5.0": "^10.5.0",
      "rollup@>=4.0.0 <4.59.0": "^4.59.0",
      "minimatch@<3.1.4": "^3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "^9.0.9",
      "svgo@4.0.0": "^4.0.1",
      "fast-xml-parser@>=5.0.0 <5.5.7": "^5.5.11",
      "lodash@<4.17.24": "^4.17.24",
      "lodash-es@<4.18.1": "^4.18.1",
      "flatted@<3.4.2": "^3.4.2",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "devalue@<5.6.4": "^5.6.4",
      "markdown-it@>=13.0.0 <14.1.1": "^14.1.1",
      "smol-toml@<1.6.1": "^1.6.1",
      "dompurify@<3.3.2": "^3.3.3",
      "yaml@>=2.0.0 <2.8.3": "^2.8.3",
      "astro-auto-import@<0.5.1": "^0.5.1"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@playform/inline": "0.1.2",
    "@tailwindcss/typography": "^0.5.19",
    "@textlint-ja/textlint-rule-preset-ai-writing": "^1.6.3",
    "@types/d3-hierarchy": "3.1.7",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/unist": "^3.0.3",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "astro-expressive-code": "0.41.7",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^0.33.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "fetch-site-metadata": "^0.2.0",
    "hastscript": "^9.0.1",
    "husky": "^9.1.7",
    "lightningcss": "^1.30.2",
    "lint-staged": "^15.2.10",
    "markdownlint-cli2": "^0.20.0",
    "mdast-util-to-hast": "^13.2.1",
    "mdast-util-to-string": "^4.0.0",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.13.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-parse": "9.0.1",
    "rehype-stringify": "10.0.1",
    "satori": "^0.18.3",
    "sharp": "^0.34.5",
    "textlint": "^15.5.4",
    "textlint-plugin-mdx": "^1.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "unist-util-visit-parents": "6.0.2",
    "vitest": "4.1.2",
    "yaml": "^2.8.2"
  }
}
